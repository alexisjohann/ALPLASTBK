\ProvidesPackage{beamerthemefehradvice}[2026/02/06 FehrAdvice Beamer Theme]

% --- Pakete ---
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\usepackage{tikz}
\usepackage{eurosym}
\usepackage{textcomp}
\usepackage{helvet}
\usepackage{tcolorbox}
\usepackage{colortbl}
\renewcommand{\familydefault}{\sfdefault}

\usetikzlibrary{calc, positioning, shapes.geometric, decorations.pathmorphing}

% =============================================================================
% FARBEN (aus REF-STYLE_SG_corporate_style_guide.tex)
% =============================================================================

% Primärfarben
\definecolor{fadarkblue}{HTML}{024079}    % Headlines, Strukturelemente
\definecolor{falightblue}{HTML}{549EDE}   % Sekundäre Elemente, Hover
\definecolor{fadarkgray}{HTML}{25212A}    % Fliesstext
\definecolor{falightgray}{HTML}{F3F5F7}   % Hintergründe, Alternation

% Sekundärfarben
\definecolor{faorange}{HTML}{DE9D3E}      % CTA, Takeaways, Warnungen
\definecolor{famint}{HTML}{7EBDAC}        % Positive Akzente, Diagramme
\definecolor{falilac}{HTML}{A1A0C6}       % Akzente, Diagramme
\definecolor{faocher}{HTML}{DECB3F}       % Hervorhebungen

% Funktionale Farben
\definecolor{fawhite}{HTML}{FFFFFF}
\definecolor{famedgray}{HTML}{666666}
\definecolor{falinegray}{HTML}{CCCCCC}
\definecolor{fasuccessgreen}{HTML}{2E8B57}
\definecolor{fadangerred}{HTML}{C0392B}

% =============================================================================
% BEAMER SETTINGS
% =============================================================================

\setbeamercolor{background canvas}{bg=fawhite}
\setbeamercolor{normal text}{fg=fadarkgray}
\setbeamercolor{frametitle}{fg=fadarkblue, bg=fawhite}
\setbeamercolor{title}{fg=fawhite, bg=fadarkblue}
\setbeamercolor{subtitle}{fg=falightblue}
\setbeamercolor{author}{fg=fawhite}
\setbeamercolor{date}{fg=fawhite!80!fadarkblue}
\setbeamercolor{institute}{fg=fawhite!80!fadarkblue}
\setbeamercolor{item}{fg=fadarkblue}
\setbeamercolor{subitem}{fg=falightblue}
\setbeamercolor{block title}{fg=fawhite, bg=fadarkblue}
\setbeamercolor{block body}{bg=falightgray}
\setbeamercolor{block title alerted}{fg=fawhite, bg=faorange}
\setbeamercolor{block body alerted}{bg=faorange!8!fawhite}
\setbeamercolor{block title example}{fg=fawhite, bg=famint!80!fadarkblue}
\setbeamercolor{block body example}{bg=famint!8!fawhite}

% Keine Default-Navigation
\setbeamertemplate{navigation symbols}{}

% Bullet Points: gefüllte Quadrate (wie FA-Slides)
\setbeamertemplate{itemize items}[square]
\setbeamertemplate{itemize item}{\color{fadarkblue}\tiny$\blacksquare$}
\setbeamertemplate{itemize subitem}{\color{falightblue}\tiny$\blacksquare$}

% Fontsizes
\setbeamerfont{frametitle}{size=\LARGE, series=\bfseries}
\setbeamerfont{framesubtitle}{size=\normalsize, series=\mdseries}
\setbeamerfont{title}{size=\Huge, series=\bfseries}
\setbeamerfont{subtitle}{size=\large, series=\mdseries}
\setbeamerfont{author}{size=\normalsize}
\setbeamerfont{date}{size=\small}
\setbeamerfont{footnote}{size=\tiny}
\setbeamerfont{page number in head/foot}{size=\scriptsize}

% =============================================================================
% TITLE PAGE (Deckblatt)
% =============================================================================

\setbeamertemplate{title page}{%
    \begin{tikzpicture}[remember picture, overlay]
        % Dunkelblauer Hintergrund (volle Seite)
        \fill[fadarkblue] (current page.south west) rectangle (current page.north east);

        % Dezenter Akzentstreifen oben
        \fill[falightblue!30!fadarkblue]
            (current page.north west) rectangle
            ([yshift=-0.6cm]current page.north east);

        % FA Logo Platzhalter (oben rechts)
        \node[anchor=north east, opacity=0.15] at ([xshift=-1cm, yshift=-0.8cm]current page.north east) {
            \begin{tikzpicture}[scale=0.4]
                \foreach \i in {0,...,3} {
                    \fill[fawhite, rounded corners=1pt]
                        (\i*0.45, 0) rectangle (\i*0.45+0.35, 1.8-\i*0.15);
                }
            \end{tikzpicture}
        };

        % Titel-Block
        \node[anchor=west, text width=11cm] at ([xshift=1.5cm, yshift=1cm]current page.west) {
            {\fontsize{22}{26}\selectfont\bfseries\usebeamercolor[fg]{title}\guillemotleft\inserttitle\guillemotright}
        };

        % Untertitel
        \node[anchor=west, text width=11cm] at ([xshift=1.5cm, yshift=-0.8cm]current page.west) {
            {\usebeamerfont{subtitle}\color{fawhite!85!fadarkblue}\insertsubtitle}
        };

        % Autor + Datum (unten links)
        \node[anchor=south west, text width=8cm] at ([xshift=1.5cm, yshift=1.5cm]current page.south west) {
            {\usebeamerfont{author}\usebeamercolor[fg]{author}\insertauthor}\\[4pt]
            {\usebeamerfont{date}\usebeamercolor[fg]{date}\insertinstitute}\\[2pt]
            {\usebeamerfont{date}\usebeamercolor[fg]{date}\insertdate}
        };

        % Horizontale Linie über Footer
        \draw[fawhite, opacity=0.3, line width=0.5pt]
            ([xshift=1.5cm, yshift=1.2cm]current page.south west) --
            ([xshift=-1.5cm, yshift=1.2cm]current page.south east);
    \end{tikzpicture}
}

% =============================================================================
% FRAME TITLE (Inhaltsseiten Header)
% =============================================================================

\setbeamertemplate{frametitle}{%
    \vskip4pt
    \begin{beamercolorbox}[wd=\paperwidth, leftskip=0.8cm, rightskip=0.8cm]{frametitle}
        \usebeamerfont{frametitle}\insertframetitle
        \ifx\insertframesubtitle\@empty\else
            \\[1pt]
            {\usebeamerfont{framesubtitle}\color{famedgray}\insertframesubtitle}
        \fi
    \end{beamercolorbox}
    \vskip-2pt
    \begin{tikzpicture}[overlay]
        \draw[fadarkblue, line width=1.5pt] (0.8,0) -- (\paperwidth-0.8cm,0);
    \end{tikzpicture}
    \vskip4pt
}

% =============================================================================
% FOOTLINE (Branded Footer)
% =============================================================================

\setbeamertemplate{footline}{%
    \begin{tikzpicture}[overlay]
        \draw[falinegray, line width=0.3pt]
            (0.8cm, 0.55cm) -- (\paperwidth-0.8cm, 0.55cm);
    \end{tikzpicture}
    \hbox{%
        \begin{beamercolorbox}[wd=.5\paperwidth, ht=0.5cm, dp=0.1cm, leftskip=0.8cm]{author in head/foot}%
            {\usebeamerfont{footnote}\color{famedgray}FehrAdvice \& Partners AG, \insertshortdate}
        \end{beamercolorbox}%
        \begin{beamercolorbox}[wd=.5\paperwidth, ht=0.5cm, dp=0.1cm, rightskip=0.8cm, right]{page number in head/foot}%
            {\usebeamerfont{page number in head/foot}\color{famedgray}\insertframenumber}
        \end{beamercolorbox}%
    }
    \vskip2pt
}

% =============================================================================
% CUSTOM COMMANDS
% =============================================================================

% --- Takeaway Box (orange Pfeil) ---
\newcommand{\takeaway}[1]{%
    \vskip3pt
    \begin{tcolorbox}[
        colback=faorange!8!white,
        colframe=faorange,
        leftrule=4pt, rightrule=0pt, toprule=0pt, bottomrule=0pt,
        left=6pt, right=6pt, top=3pt, bottom=3pt,
        sharp corners
    ]
    {\color{faorange}\bfseries$\rightarrow$}~{\small\bfseries\color{fadarkgray}#1}
    \end{tcolorbox}
}

% --- Insight Box (dunkelblau) ---
\newcommand{\insightbox}[2]{%
    \begin{tcolorbox}[
        colback=fadarkblue!5!white,
        colframe=fadarkblue,
        title={\color{fawhite}\bfseries\small #1},
        left=4pt, right=4pt, top=2pt, bottom=2pt
    ]
    #2
    \end{tcolorbox}
}

% --- Nummerierte Punkte (blaue Kreise) ---
\newcommand{\numpoint}[2]{%
    \begin{tikzpicture}[baseline=-3pt]
        \node[circle, fill=fadarkblue, text=fawhite, font=\bfseries\small,
              minimum size=0.65cm, inner sep=0pt] {#1};
    \end{tikzpicture}
    \hspace{4pt}{\bfseries\color{fadarkblue}#2}%
}

% --- Vergleichsbalken (horizontal) ---
\newcommand{\compbar}[4]{% label, value, maxwidth (0-1), color
    \begin{tikzpicture}[baseline=-2pt]
        \fill[#4] (0,0) rectangle (#3*8cm, 0.5cm);
        \fill[#4!20!white] (#3*8cm, 0) rectangle (8cm, 0.5cm);
        \node[anchor=west, font=\small\color{fadarkgray}] at (8.3cm, 0.25cm) {#2};
        \node[anchor=east, font=\small\bfseries\color{fadarkgray}] at (-0.2cm, 0.25cm) {#1};
    \end{tikzpicture}
}

% --- Kennzahl gross ---
\newcommand{\bigstat}[3]{% number, label, color
    \begin{center}
        {\fontsize{28}{32}\selectfont\bfseries\color{#3}#1}\\[2pt]
        {\small\color{famedgray}#2}
    \end{center}
}

% --- Zweispalten-Vergleich ---
\newenvironment{facompare}[2]{%
    \begin{columns}[T]
        \begin{column}{0.48\textwidth}
            \begin{tcolorbox}[colback=falightgray, colframe=fasuccessgreen!60!fadarkblue,
                              title={\color{fawhite}\bfseries #1},
                              colbacktitle=fasuccessgreen!80!fadarkblue]
}{%
            \end{tcolorbox}
        \end{column}
}

% --- Schlussseite ---
\newcommand{\closingslide}[3]{% title, contact_name, email
    \begin{frame}[plain]
        \begin{tikzpicture}[remember picture, overlay]
            \fill[fadarkblue] (current page.south west) rectangle (current page.north east);

            % Danke-Titel
            \node[anchor=center, text width=10cm, align=center]
                at ([yshift=1.5cm]current page.center) {
                {\fontsize{24}{30}\selectfont\bfseries\color{fawhite}#1}
            };

            % Horizontale Linie
            \draw[fawhite, opacity=0.3, line width=0.5pt]
                ([xshift=2cm, yshift=-0.5cm]current page.center) --
                ([xshift=-2cm, yshift=-0.5cm]current page.center);

            % Kontakt
            \node[anchor=center, text width=8cm, align=center]
                at ([yshift=-1.5cm]current page.center) {
                {\normalsize\color{fawhite!90!fadarkblue}Kontakt:}\\[6pt]
                {\large\bfseries\color{fawhite}#2}\\[4pt]
                {\normalsize\color{faorange}#3}\\[4pt]
                {\normalsize\color{fawhite!80!fadarkblue}www.fehradvice.com}
            };

            % Footer
            \draw[fawhite, opacity=0.3, line width=0.5pt]
                ([xshift=1.5cm, yshift=1.2cm]current page.south west) --
                ([xshift=-1.5cm, yshift=1.2cm]current page.south east);
            \node[anchor=south, font=\tiny, color=fawhite!60!fadarkblue]
                at ([yshift=0.5cm]current page.south) {
                FehrAdvice \& Partners AG \quad|\quad Z\"urich \quad|\quad Wien \quad|\quad Berlin
            };
        \end{tikzpicture}
    \end{frame}
}
