  "mapping_functions": {
    "_comment": "Mapping von Original-Metrik auf θ ∈ [0,1] - separat definiert",

    "cohens_d": {
      "formula": "θ = min(1, d / 1.0)",
      "anchors": {"d_0.2": 0.30, "d_0.5": 0.60, "d_0.8": 0.90},
      "alternative": "piecewise_linear or sigmoid"
    },

    "smd": {
      "formula": "θ = min(1, SMD / 1.0)",
      "note": "Same as Cohen's d"
    },

    "percentage_points": {
      "formula": "θ = min(1, pp / 50)",
      "note": "50pp = maximum practical effect"
    },

    "percent_change": {
      "formula": "θ = min(1, |%| / 30)",
      "note": "30% = large effect for consumption outcomes"
    }
  },

