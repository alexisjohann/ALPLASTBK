@techreport{efferson2022superadditive,
  title={Super-Additive Cooperation},
  author={Efferson, Charles and Bernhard, Helen and Fischbacher, Urs and Fehr, Ernst},
  institution={CESifo},
  type={Working Paper},
  number={10133},
  year={2022},
  month={December},
  url={https://ssrn.com/abstract=4301645},
  use_for = {CORE-HOW, CORE-WHO, DOMAIN-COOP, LIT-FEH, LIT-FEHR, LIT-O},
  evidence_tier = {2},
  theory_support = {MS-SP-016, MS-SP-008, MS-SP-001, MS-SP-005},
  identification = {simulation, evolutionary model, field experiment PNG},
  external_validity = {Papua New Guinea, Ngenikas and Perepkas, theoretical generality},
  parameter = {super_additivity_threshold = significant, ingroup_escalation = positive, outgroup_deescalation = negative},
  case_registry = {CAS-879},
  ebf_migration_status = {complete},
  abstract = {Neither repeated interactions alone nor intergroup competition alone reliably support cooperation evolution. Repeated interactions fail due to ambiguous reciprocity strategies. Intergroup competition requires delicate conditions. However, COMBINING both mechanisms triggers powerful synergies: super-additive cooperation where joint effect exceeds sum of individual effects. Evolved strategies show cooperative reciprocity (escalation) with ingroup partners and uncooperative reciprocity (de-escalation) with outgroup partners. Field experiment in Papua New Guinea with Ngenikas and Perepkas confirms exactly this pattern. Key implication: mechanisms hypothesized for cooperation are not mutually exclusive - their INTERACTION may be uniquely human.},
  keywords = {evolution of cooperation, reciprocity, intergroup competition, social dilemma, super-additivity, complementarity},
  note = {Level 4 integration - KEY PAPER for gamma-complementarity: defines MS-SP-016 Super-Additive Cooperation theory}
}

