@techreport{yang2020strategy,
  title = {How Do {CEOs} Make Strategy?},
  author = {Yang, Mu-Jeung and Christensen, Michael and Bloom, Nicholas and Sadun, Raffaella and Rivkin, Jan},
  year = {2020},
  institution = {Harvard Business School},
  type = {Working Paper},
  number = {21-063},
  use_for = {LIT-O, DOMAIN-CONSULTING},
  theory_support = {MS-IN-001},
  evidence_tier = {2},
  parameter = {strategy_practice_score: 1SD increase = 1.92x firm size; 1SD = 4.7pct annual employment growth; 1SD = 13pct more decisions but 28pct longer decision time},
  notes = {Survey of 262 HBS-alumni CEOs measuring Strategy Practices (Formalization, Development, Implementation) on 14-item scoring grid. Key findings: (1) Enormous heterogeneity in how structured CEOs make strategy — from pure intuition to highly evidence-based. (2) More structured processes correlate with 1.92x larger firms and 4.7pct faster annual growth. (3) RDD around Michael Porter's 1983 HBS curriculum change shows MBA education causally affects strategy practices decades later — Porter increased Formalization but decreased Implementation focus. (4) Industry explains almost zero variance in strategy practices (adj R2 near 0). Directly relevant to Kaufland KIBSM: strategy practices must be measured and developed at Filialleitung level. WMS methodology extended to strategy domain.},
}

@techreport{dur2020leadership,
  title = {Labor-Market Conditions and Leadership Styles},
  author = {Dur, Robert and Kvaløy, Ola and Schöttner, Arne},
  year = {2020},
  institution = {IZA Institute of Labor Economics},
  type = {Discussion Paper},
  number = {13860},
  month = {November},
  use_for = {LIT-O, DOMAIN-CONSULTING},
  theory_support = {MS-IB-001, MS-SP-001},
  evidence_tier = {2},
  parameter = {leadership_style_conditions: Prop1 competitive wages exclude unfriendly styles; Prop2 non-competitive wages (union bargaining w_bar > u) enable conditional unfriendly leadership when (1-rho)*k_U_l + max(s-(w_bar-u) 0) < rho*s; Prop4 income gap u_l > u reduces cost of spiteful leaders making unfriendly styles more prevalent; 10pct abusive supervision prevalence (Tepper 2017)},
  notes = {Formal economic model of leadership styles under different labor-market conditions. Two styles: friendly (praise conditional on good performance) and unfriendly (social punishment conditional on bad performance). Key result: Under competitive wage-setting, unfriendly leadership is NEVER optimal (Proposition 1). Under non-competitive wage-setting (binding wage floor from unions, minimum wage, limited liability), unfriendly leadership emerges because it extracts worker rents (Proposition 2). Self-enforcement mechanism: moderately altruistic leaders credibly commit to praise; moderately spiteful leaders credibly commit to punishment. Selfish leaders cannot credibly commit (one-shot game). Income gap (leader better off than worker) makes spiteful leaders cheaper to employ, increasing unfriendly leadership (Proposition 4). Directly relevant to Kaufland: Tarifvertrag creates non-competitive wage-setting per Proposition 2. Leader selection (WHO-01) should screen for altruistic social preferences. FK-Akademie should train praise-based leadership and build awareness of structural incentives for unfriendly styles.},
}

