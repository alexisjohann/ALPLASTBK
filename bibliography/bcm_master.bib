@article{aaker1990consumer,
  title={Consumer Evaluations of Brand Extensions},
  author={Aaker, David A. and Keller, Kevin Lane},
  journal={Journal of Marketing},
  volume={54},
  number={1},
  pages={27--41},
  year={1990},
  doi={10.1177/002224299005400102},
  evidence_tier = {1},
  use_for = {CAT-33, CORE-WHAT, CORE-WHO, LIT-O},
  theory_support = {MS-BX-001},
  parameter = {three_fit_dimensions: transfer, complement, substitute; quality_interaction: brand quality moderates fit effect; perceived_fit_evaluation_beta: 0.35-0.55},
  identification = {experimental, consumer surveys, brand evaluation},
  external_validity = {brand management, product line extensions, category extensions},
  session_ref = {ubs-growth-marketing-analyses},
  notes = {FOUNDATIONAL paper on brand extensions. Three dimensions: Transfer (manufacturing skills), Complement (usage together), Substitute (replaceable). Brand quality moderates. For UBS eSIM: Transfer LOW (banking ≠ telco), Complement MEDIUM-HIGH (travel + finance), Substitute LOW. Overall fit MODERATE - requires strong marketing support.}
}

@article{voelckner2006drivers,
  title={Drivers of Brand Extension Success},
  author={V{\"o}lckner, Franziska and Sattler, Henrik},
  journal={Journal of Marketing},
  volume={70},
  number={2},
  pages={18--34},
  year={2006},
  doi={10.1509/jmkg.70.2.018},
