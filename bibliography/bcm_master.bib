@article{fehr1993reciprocity,
  title = {Does Fairness Prevent Market Clearing? An Experimental Investigation},
  author = {Fehr, Ernst and Kirchler, Erich and Weichbold, Andreas and G{\"a}chter, Simon},
  year = {1993},
  journal = {Quarterly Journal of Economics},
  volume = {108},
  number = {2},
  pages = {437--459},
  doi = {10.1162/0033559320437},
  use_for = {CORE-WHO, LIT-FEH, LIT-O, METHOD-EXP},
  abstract = {This paper reports results from competitive experimental markets in which buyers can reward sellers who provide more than the required minimum quality. We find that reciprocal fairness considerations significantly impact market outcomes: many sellers voluntarily provide quality above the minimum, and buyers reciprocate by paying prices above market-clearing levels. These fairness norms prevent the market from clearing, demonstrating that social preferences can override pure self-interest in competitive settings.},
  ebf_reference_count = {7},
  ebf_migration_status = {pending},
  theory_support = {MS-SP-001},
  evidence_tier = {1},
}
@article{fehr2000cooperation,
  title = {Cooperation and Punishment in Public Goods Experiments},
  author = {Fehr, Ernst and G{\"a}chter, Simon},
  year = {2000},
  journal = {American Economic Review},
  volume = {90},
  number = {4},
  pages = {980--994},
  doi = {10.1006/game.1999.0765},
  use_for = {CORE-WHO, LIT-FEH, LIT-O, METHOD-EXP},
  abstract = {This paper provides experimental evidence on the enforcement of social norms through punishment. In public goods experiments without punishment opportunities, cooperation typically breaks down. However, when subjects have the opportunity to punish free riders at a cost to themselves, cooperation is sustained at high levels. The threat of punishment deters free riding even though punishing is costly and does not provide material benefits to the punisher. These results demonstrate that humans have a strong propensity for altruistic punishment that supports cooperative outcomes.},
  ebf_reference_count = {1},
  ebf_migration_status = {pending},
  theory_support = {MS-SP-004},
  evidence_tier = {1},
}
