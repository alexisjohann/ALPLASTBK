}

@article{park1991evaluation,
  title={Evaluation of Brand Extensions: The Role of Product Feature Similarity and Brand Concept Consistency},
  author={Park, C. Whan and Milberg, Sandra and Lawson, Robert},
  journal={Journal of Consumer Research},
  volume={18},
  number={2},
  pages={185--193},
  year={1991},
  doi={10.1086/209251},
  evidence_tier = {1},
  use_for = {CAT-33, CORE-WHAT, LIT-O},
  theory_support = {MS-BX-001},
  parameter = {brand_concept_types: functional vs prestige; concept_consistency_effect: prestige brands can extend further than functional brands; feature_similarity: necessary but not sufficient for positive evaluation},
  identification = {experimental, consumer evaluations},
  external_validity = {brand management, luxury brands, service brands},
  session_ref = {ubs-growth-marketing-analyses},
  notes = {KEY DISTINCTION: functional vs prestige brand concepts. Prestige brands (like UBS) can extend FURTHER than functional brands because prestige is more abstract and transferable. UBS as prestige financial brand has MORE extension latitude than a functional bank brand. Supports eSIM extension if positioned as prestige lifestyle service.}
}

@article{broniarczyk1994importance,
