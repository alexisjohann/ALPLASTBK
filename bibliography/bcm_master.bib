@article{dustmann2025immigration,
  title={The Effects of Immigration on Places and People -- Identification and Interpretation},
  author={Dustmann, Christian and Otten, Sebastian and Schönberg, Uta and Stuhler, Jan},
  journal={Working Paper},
  year={2025},
  % === EVIDENCE CLASSIFICATION ===
  evidence_tier = {2},
  use_for = {LIT-CARD, DOMAIN-LABOR, DOMAIN-MIGRATION, CORE-HOW, CORE-WHERE, parameter, LLMMC, Ch.4},
  theory_support = {MS-LM-001, MS-LM-003, MS-LM-004},
  parameter = {phi_inverse_labor_demand = -1.95, eta_P_labor_supply_place = 4.64, eta_E_labor_supply_worker = 3.68, regional_employment_effect = -0.873, displacement_effect = 0.139, pure_wage_effect = -0.188},
  identification = {spatial_equilibrium, decomposition_framework, IV_historical_settlement},
  external_validity = {Germany, US, meta_analysis, generalizable_framework},
  notes = {LANDMARK METHODOLOGICAL PAPER. Reconciles conflicting immigration literatures by distinguishing place-based vs worker-level effects. KEY INSIGHT: Regional approaches measure effects on PLACES (including relocation), worker-level approaches measure effects on PEOPLE (natives who stay). Both are valid but answer different questions. Introduces unified framework with displacement, crowding-out, and relocation effects. Essential for interpreting immigration research.},
  keywords = {immigration, labor market, spatial equilibrium, identification, places vs people, displacement, wage effects},
  ebf_reference_count = {2},
  ebf_migration_status = {complete},
  abstract = {We discuss how regional and worker-level approaches to studying immigration address different but related questions. Regional approaches estimate the impact on natives who remain in a region, while worker-level studies track individuals regardless of location. The difference relates to native relocation responses. We develop a unified framework showing that regional effects combine displacement (natives leaving), crowding-out (reduced inflows), and pure wage effects. Using German data, we estimate key structural parameters: inverse labor demand elasticity phi=-1.95, place-based labor supply elasticity eta_P=4.64, and worker-level supply elasticity eta_E=3.68.}
}

