}

@article{prahl2017understanding,
  title={Understanding Algorithm Aversion: When Is Advice from Automation Discounted?},
  author={Prahl, Andrew and Van Swol, Lyn},
  journal={Journal of Forecasting},
  volume={36},
  number={6},
  pages={691--702},
  year={2017},
  doi={10.1002/for.2464},
  evidence_tier = {2},
  use_for = {CAT-25, CORE-AWARE, LIT-O},
  theory_support = {MS-AI-002},
  parameter = {advice_discounting: algorithm advice discounted more than human advice after error; transparency_effect: explaining algorithm logic reduces but does not eliminate aversion},
  identification = {experimental, advice-taking paradigm},
  external_validity = {forecasting, advisory services},
  session_ref = {ubs-growth-marketing-analyses},
  notes = {Examines advice discounting in human vs algorithm advisors. Transparency helps but does not fully solve aversion. Relevant for UBS Mortgage GPT: explaining how rates are calculated helps but trust requires more than transparency.}
}

% --- B2: Technology Acceptance Model (TAM) / UTAUT ---

@article{davis1989perceived,
  title={Perceived Usefulness, Perceived Ease of Use, and User Acceptance of Information Technology},
  author={Davis, Fred D.},
  journal={MIS Quarterly},
  volume={13},
  number={3},
  pages={319--340},
  year={1989},
  doi={10.2307/249008},
  evidence_tier = {1},
  use_for = {CAT-32, CORE-READY, CORE-AWARE, LIT-O},
  theory_support = {MS-TC-001},
  parameter = {perceived_usefulness_R2: PU explains ~40pct of usage intention; perceived_ease_of_use: PEOU has direct and indirect (via PU) effects on intention; PU_beta: 0.42-0.66 across studies},
  identification = {empirical, survey, longitudinal},
  external_validity = {information systems, broad technology contexts, replicated extensively},
  session_ref = {ubs-growth-marketing-analyses},
  notes = {FOUNDATIONAL paper for Technology Acceptance Model. Most cited IS paper ever. PU (Perceived Usefulness) is strongest predictor of technology adoption. PEOU (Perceived Ease of Use) works primarily through PU. For UBS: both Mortgage GPT and eSIM must demonstrate clear usefulness AND be easy to use.}
}

@article{venkatesh2003user,
  title={User Acceptance of Information Technology: Toward a Unified View},
  author={Venkatesh, Viswanath and Morris, Michael G. and Davis, Gordon B. and Davis, Fred D.},
  journal={MIS Quarterly},
  volume={27},
  number={3},
  pages={425--478},
