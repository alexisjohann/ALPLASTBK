@techreport{autor2025misaligned,
  title = {Misaligned by Design: Incentive Failures in Machine Learning},
  author = {Autor, David and Caplin, Andrew and Martin, Daniel J. and Marx, Philip},
  year = {2025},
  month = {November},
  institution = {National Bureau of Economic Research},
  type = {Working Paper},
  number = {34504},
  series = {NBER Working Paper Series},
  doi = {10.3386/w34504},
  abstract = {Given a user with a well-defined utility function, this paper studies whether or not incentivized Machine Learners (MLs) will provide accurate probabilistic assessments of states of the world needed for good decision-making. We first identify a broadly applicable condition, the Aligned Learning Premise (ALP), under which they will: that the optimal action depends only on the most likely state. Yet the ALP fails in many real-world cases, including hiring decisions, medical screening, and loan approvals. We show that when the ALP fails, standard ML loss functions can systematically disincentivize the provision of accurate probabilistic assessments, producing ML systems that are misaligned with user utility. Additionally, we provide a new result in the theory of proper scoring rules by showing that, contrary to common belief, ex-post utility weighting is necessary for alignment when costs of wrong decisions are unequal.},
  use_for = {LIT-AUTOR, DOMAIN-AI, CORE-HOW, CORE-WHAT, CORE-AWARE},
  theory_support = {MS-MD-002},
  evidence_tier = {2},
  parameter = {ALP_condition = most_likely_state_determines_optimal_action, misalignment_source = asymmetric_error_costs, alignment_fix = utility_weighted_scoring},
  identification = {formal proofs, simulation experiments, proper scoring rule theory},
  external_validity = {General ML classification settings with asymmetric loss; hiring decisions, medical screening, loan approvals},
  session_ref = {EBF-S-2026-02-20-AI-001},
  notes = {FOUNDATIONAL FRAMEWORK: Establishes Aligned Learning Premise (ALP) - the condition under which standard ML training aligns with user utility. Shows ALP fails when different errors have different costs (Type I vs Type II). Proves ex-post utility weighting is necessary for alignment. Connects proper scoring rules, Blackwell information ordering, and mechanism design to ML training.},
}

