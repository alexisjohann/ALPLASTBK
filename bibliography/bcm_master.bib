  abstract={We analyze a three-stage game in which a Sender may offer help, a Receiver can accept or ask for help, and the Sender decides whether to grant the request. Asking for help reveals need, creating fear of rejection. Not offering reveals low valuation, creating discouragement. We characterize equilibria showing: (1) fear of rejection leads to non-monotonic asking in need, (2) discouragement effect reduces asking after non-offers, (3) a waiting trap can emerge where both parties inefficiently delay. Applications include workplace helping, welfare take-up, and healthcare seeking.},
  keywords={helping behavior, asking for help, fear of rejection, offering, self-image, information avoidance, signaling},
  jel={D03, D23, D64, D82, D83, D91},
  use_for = {LIT-BENABOU, LIT-LOEWENSTEIN, CORE-WHO, CORE-AWARE, CORE-HOW, DOMAIN-SOCIAL, DOMAIN-ORG},
  theory_support = {MS-IB-002, MS-IB-016, MS-IB-018, MS-SP-001, MS-SP-016},
  parameter = {
    lambda_R = rejection_sensitivity in [1.5, 3.0];
    alpha = rejection_scaling in [0, 1];
    mu = image_concern in [0, 1];
    g = generosity continuous;
    w = need continuous;
    c = helping_cost continuous;
    pi = probability_of_offer in [0, 1];
    w_star = asking_threshold continuous;
    g_tilde = offering_threshold continuous
  },
  ebf_reference_count = {8},
