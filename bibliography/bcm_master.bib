% --- B1: Algorithm Aversion / Algorithm Appreciation ---

@article{dietvorst2015algorithm,
  title={Algorithm Aversion: People Erroneously Avoid Algorithms After Seeing Them Err},
  author={Dietvorst, Berkeley J. and Simmons, Joseph P. and Massey, Cade},
  journal={Journal of Experimental Psychology: General},
  volume={144},
  number={1},
  pages={114--126},
  year={2015},
  doi={10.1037/xge0000033},
  evidence_tier = {1},
  use_for = {CAT-25, CORE-AWARE, CORE-READY, LIT-O},
  theory_support = {MS-AI-002},
  parameter = {algorithm_aversion: after seeing algorithm err people choose human forecasters despite worse performance; forecaster_choice_after_error: ~40pct choose algorithm vs ~50pct human after seeing both err},
  identification = {experimental, lab studies, forecasting tasks},
  external_validity = {prediction tasks, forecasting, advisory services},
  session_ref = {ubs-growth-marketing-analyses},
  notes = {FOUNDATIONAL paper on algorithm aversion. People lose confidence in algorithms more quickly than in humans after seeing both make identical errors. Key for UBS Mortgage GPT: users may abandon AI advisor after first perceived error even if AI outperforms human advisors.}
}

@article{dietvorst2018overcoming,
  title={Overcoming Algorithm Aversion: People Will Use Imperfect Algorithms If They Can (Even Slightly) Modify Them},
  author={Dietvorst, Berkeley J. and Simmons, Joseph P. and Massey, Cade},
  journal={Management Science},
  volume={64},
  number={3},
  pages={1155--1170},
  year={2018},
  doi={10.1287/mnsc.2016.2643},
  evidence_tier = {1},
  use_for = {CAT-25, CORE-AWARE, CORE-READY, DOMAIN-CONSULTING, LIT-O},
  theory_support = {MS-AI-002},
  parameter = {algorithm_use_with_modification: 73pct use algorithm when modifiable vs 32pct when not; illusion_of_control_effect: even trivial modification rights increase adoption substantially},
  identification = {experimental, lab studies, forecasting tasks},
  external_validity = {advisory services, AI-assisted decision making, financial services},
  session_ref = {ubs-growth-marketing-analyses},
  notes = {KEY FINDING: 73pct vs 32pct usage when users can modify algorithm output. Critical for UBS Mortgage GPT design: allowing users to adjust parameters (e.g. income, preferences) dramatically increases trust and adoption. Illusion of control as design principle.}
}

@article{logg2019algorithm,
  title={Algorithm Appreciation: People Prefer Algorithmic to Human Judgment},
  author={Logg, Jennifer M. and Minson, Julia A. and Moore, Don A.},
  journal={Organizational Behavior and Human Decision Processes},
  volume={151},
  pages={90--103},
  year={2019},
  doi={10.1016/j.obhdp.2018.12.005},
  evidence_tier = {2},
  use_for = {CAT-25, CORE-AWARE, CORE-READY, LIT-O},
  theory_support = {MS-AI-003},
  parameter = {algorithm_appreciation: 66pct prefer algorithm over human for objective tasks; domain_moderator: appreciation stronger for objective vs subjective judgments},
  identification = {experimental, multiple studies, estimation tasks},
  external_validity = {estimation tasks, forecasting, advisory services with objective components},
  session_ref = {ubs-growth-marketing-analyses},
  notes = {COUNTERPOINT to algorithm aversion: people PREFER algorithms for many tasks. Key moderator: objectivity of task. Mortgage rate calculation = objective → higher algorithm appreciation. Lifestyle advice = subjective → algorithm aversion. Critical for UBS Mortgage GPT: separate objective (rates) from subjective (advice) components.}
}

@article{longoni2019resistance,
  title={Resistance to Medical Artificial Intelligence},
  author={Longoni, Chiara and Bonezzi, Andrea and Morewedge, Carey K.},
  journal={Journal of Consumer Research},
  volume={46},
  number={4},
  pages={629--650},
  year={2019},
  doi={10.1093/jcr/ucz013},
  evidence_tier = {1},
  use_for = {CAT-25, CORE-AWARE, CORE-WHO, LIT-O},
  theory_support = {MS-AI-002},
  parameter = {uniqueness_neglect: AI perceived as unable to account for individual uniqueness; resistance_driver: concern about being treated as average not as individual},
  identification = {experimental, multiple studies, medical and consumer contexts},
  external_validity = {medical AI, financial advisory, personalized services},
  session_ref = {ubs-growth-marketing-analyses},
  notes = {KEY MECHANISM: Uniqueness neglect - people resist AI because they believe AI cannot account for their unique circumstances. Critical for UBS Mortgage GPT: must demonstrate personalization capability. Swiss mortgage market has high individual variation (canton, income, property type).}
}

@article{castelo2019task,
  title={Task-Dependent Algorithm Aversion},
  author={Castelo, Noah and Bos, Maarten W. and Lehmann, Donald R.},
  journal={Journal of Marketing Research},
  volume={56},
  number={5},
  pages={809--825},
  year={2019},
  doi={10.1177/0022243719851788},
  evidence_tier = {1},
  use_for = {CAT-25, CORE-AWARE, CORE-WHAT, LIT-O},
  theory_support = {MS-AI-002, MS-AI-003},
  parameter = {task_objectivity_moderator: objective tasks → algorithm preference; subjective tasks → human preference; lay_theory: people hold implicit theories about what AI can and cannot do},
  identification = {experimental, multiple studies, various task types},
  external_validity = {marketing, advisory services, financial services, creative tasks},
  session_ref = {ubs-growth-marketing-analyses},
  notes = {BRIDGES aversion and appreciation: task objectivity is the key moderator. Objective tasks (calculation, data) → algorithm preferred. Subjective tasks (judgment, empathy) → human preferred. For UBS Mortgage GPT: rate calculation (objective) → AI accepted; life situation advice (subjective) → human handoff needed. Supports hybrid human-AI architecture.}
}

@inproceedings{jussupow2020algorithm,
