@article{dietz2026actionable,
  title = {Building Actionable Theories: The Role of Causal Constructs},
  author = {Dietz, Joerg},
  journal = {The Leadership Quarterly},
  year = {2026},
  volume = {37},
  pages = {101929},
  doi = {10.1016/j.leaqua.2025.101929},
