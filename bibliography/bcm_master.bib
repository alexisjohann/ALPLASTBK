  session_ref = {ubs-growth-marketing-analyses},
  notes = {COMPREHENSIVE REVIEW synthesizing algorithm aversion research. Identifies 5 antecedents and 4 moderators. Framework useful for systematic UBS Mortgage GPT design. Key insight: algorithm aversion is not monolithic - depends on interaction of task, advisor, person, and environment characteristics.}
}

@article{burton2020systematic,
  title={A Systematic Review of Algorithm Aversion in Augmented Decision Making},
  author={Burton, Jason W. and Stein, Mari-Klara and Jensen, Tina B.},
  journal={Journal of Behavioral Decision Making},
  volume={33},
  number={2},
  pages={220--239},
  year={2020},
