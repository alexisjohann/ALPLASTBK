@unpublished{rossinslater2026preschool,
  title = {The Impact of Preschool Entry Age on Children's Behavioral and Developmental Health in Medicaid},
  author = {Rossin-Slater, Maya and Sabety, Adriana and Wu, Hannes},
  year = {2026},
  note = {NBER Working Paper No. 34677},
  doi = {10.3386/w34677},
  url = {https://www.nber.org/papers/w34677},
  % === EVIDENCE CLASSIFICATION (LEVEL 3 CASE) ===
  evidence_tier = {2},
  integration_level = {3},
  integration_level_name = {CASE},
  use_for = {LIT-O, DOMAIN-HEALTH, DOMAIN-EDUCATION, DOMAIN-POLICY, CORE-AWARE, CORE-WHEN, CORE-STAGE, case},
  theory_support = {MS-SF-002, cunha2007technology, heckman2006skill},
  case_integration = {CAS-915},
  parameter = {ADHD_diagnosis_increase = 16.9pct_p001, speech_language_diagnosis_increase = 9.3pct_p001, hearing_vision_diagnosis_increase = 14.8pct_p001, preschool_attendance_increase = 12.4pp, RD_bandwidth = 90days, diagnosis_persistence = none_by_age10, treatment_increase = 12.2pct_ADHD_stimulants, IDEA_receipt_increase = 6.3pct, Medicaid_spending_increase = 104USD_annual},
  identification = {regression_discontinuity, school_entry_cutoff, N_2400000, 32_states},
  external_validity = {USA_Medicaid, low_income_children, 32_states, 2008_2018, ages_4_10},
  session_ref = {EBF-S-2026-02-05-BMW-001},
  abstract = {We study the effects of preschool entry on children's behavioral and developmental health. Using administrative Medicaid data on approximately 2.4 million children in 32 US states, we exploit variation in school-entry age cutoff dates to estimate regression discontinuity models. Preschool entry leads to increases in diagnoses of ADHD, speech and language disorders, and hearing and vision conditions. For ADHD and speech/language disorders, these effects are driven by children who also receive treatment (medication and IDEA-covered special education, respectively), dissipate by age 10, and are larger in areas with higher quality preschool programs. We estimate a $104 annual per-child increase in Medicaid spending.},
  keywords = {preschool, ADHD, school entry age, regression discontinuity, Medicaid, early childhood, behavioral health, developmental health, diagnosis, special education, IDEA},
  notes = {KEY FINDING: Preschool entry FACILITATES early diagnosis of behavioral/developmental conditions - NOT causing them. Mechanism: institutional environment (teachers, structured setting) enables observation and referral. Children born just before cutoff enter preschool one year earlier and receive diagnoses sooner. Effects dissipate by age 10 (diagnosis timing, not incidence). Higher quality preschools show LARGER effects - consistent with detection mechanism. $104/year Medicaid cost increase is modest relative to early intervention benefits. Extends Cunha/Heckman skill formation framework by showing institutions as AWARENESS CATALYSTS for existing conditions.}
}

