  theory_support = {MS-CM-001, MS-EC-001},
  parameter = {arousal_virality_high = 0.186, arousal_virality_low = 0.026, tie_strength_virality = 1.432, lsm_virality = 0.025, empathy_virality = -0.069, explanation_virality = -0.011},
