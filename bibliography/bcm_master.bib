@article{fehr2012lure,
  title={The Lure of Authority: Motivation and Incentive Effects of Power},
  author={Fehr, Ernst and Herz, Holger and Wilkening, Tom},
  year={2013},
  journal={American Economic Review},
  volume={103},
  number={4},
  pages={1325--1359},
  doi={10.1257/aer.103.4.1325},
  keywords={authority, delegation, power, incentives, experiments, regret aversion, Aghion-Tirole, formal authority, real authority},
  jel={C92, D83, D23, D86, M54},
  abstract={Authority and power permeate political, social, and economic life, but empirical knowledge about the motivational origins and consequences of authority is limited. We study the motivation and incentive effects of authority experimentally in an authority-delegation game. Individuals often retain authority even when its delegation is in their material interest – suggesting that authority has non-pecuniary consequences for utility. Authority also leads to over-provision of effort by the controlling parties, while a large percentage of subordinates under-provide effort despite pecuniary incentives to the contrary.},
  use_for = {CORE-WHO, CORE-WHERE, DOMAIN-ORG, LIT-FEH, LIT-FEHR},
  theory_support = {MS-SP-001, MS-IB-001, MS-IN-003, MS-IF-005},
  evidence_tier = {1},
  parameter = {underdelegation rate = 35-43% (vs 100% predicted); controlling party over-effort = +10-15 units above NE; subordinate zero-effort = 30-50%; overruling reduces delegation by 20-25pp; welfare loss from underdelegation = 30% in PHIGH; regret aversion explains all three deviations},
  identification = {RCT (lab experiment, authority-delegation game, 4 treatments LOW/HIGH/PLOW/PHIGH)},
  external_validity = {lab (University of Zurich + ETH, N=504, student subjects)},
  session_ref = {EBF-S-2026-01-29-SWSM-001},
  swsm_author = {Fehr},
  swsm_validated = {true},
  paper_file = {papers/PAP-fehr2012lure.txt},
  notes = {Published in AER 2013 (Top-5). Previously UBS Center Working Paper No. 2 (2012). Key findings: (1) Under-delegation: 35-43% retain authority in HIGH/PHIGH despite delegation being materially optimal - formal authority has intrinsic value. (2) Over-effort: controlling parties provide 10-15 units above Nash Equilibrium - authority motivates effort beyond material incentives. (3) Subordinate shirking: 30-50% provide zero effort despite positive incentives - lack of authority demotivates. (4) Overruling effect: principals who are overruled reduce delegation probability by 20-25pp in subsequent periods. (5) Regret aversion (Loomes/Sugden 1982) explains all three deviations: loser regret drives over-effort, overrule regret drives underdelegation. Tests Aghion-Tirole (1997) formal vs real authority model. PHIGH50 treatment (50-period) confirms persistence. 504 subjects across 6 treatments at University of Zurich and ETH.},
  ebf_reference_count = {12},
  ebf_migration_status = {complete},
  working_paper = {UBS Center Working Paper Series No. 2, November 2012}
}
@article{bartling2014intrinsic,
  title={The Intrinsic Value of Decision Rights},
  author={Bartling, Bj{\"o}rn and Fehr, Ernst and Herz, Holger},
  year={2014},
  journal={Econometrica},
  volume={82},
  number={6},
  pages={2005--2039},
  doi={10.3982/ECTA11564},
  keywords={decision rights, control, delegation, intrinsic value, private benefits of control, incomplete contracts, laboratory experiment},
  jel={C91, D03, D23, D86, G34},
  abstract={We use a revealed preference approach to disentangle the intrinsic and instrumental value of decision rights. Our experimental method exploits the fact that the intrinsic value affects choices only if an individual actually has decision rights, while the instrumental value can be measured when the individual has no decision rights. Our results show that the large majority of subjects intrinsically value decision rights. The intrinsic value of decision rights has important implications for corporate governance and organizational design because it suggests the existence of non-transferable private benefits of control.},
  use_for = {CORE-WHO, CORE-WHERE, DOMAIN-ORG, LIT-FEH},
  theory_support = {MS-IN-003, MS-IF-005, MS-IB-001},
  evidence_tier = {1},
  parameter = {control_premium = 16.7% average; 83% of principals assign positive intrinsic value; Cronbach alpha = 0.62-0.77; intrinsic value scales linearly with stake size; intrinsic value decreases with conflict of interest},
  identification = {RCT (lab experiment with delegation game + lottery task, BDM mechanism)},
  external_validity = {lab (University of Zurich, N=172, student subjects)},
  session_ref = {},
  notes = {Walras-Bowley Lecture by Ernst Fehr at Econometric Society European Meetings 2012. Novel two-part experimental design: Part 1 delegation game elicits indifference point between keeping/delegating decision right; Part 2 lottery task measures certainty equivalents of resulting control vs delegation lotteries. Key insight: difference in certainty equivalents = intrinsic value of decision rights (after controlling for risk preferences, social preferences, ambiguity aversion by design). Alternative explanations ruled out: loss aversion (no correlation r=-0.05), illusion of control (91% zero WTP for rolling dice), preference reversals (no systematic high-amount pattern), reciprocity (opposite direction). Control experiment with N=68 confirms near-zero WTP for delegation when corner solutions. Directly relevant to EBF: establishes that decision rights have non-transferable private benefits (Grossman-Hart-Moore property rights theory) and provides quantitative measure of autonomy preference.}
}
