  use_for = {LIT-O, METHOD-DESIGN, CORE-HOW},
  theory_support = {MS-IF-005},
  evidence_tier = {2},
  parameter = {},
  identification = {Conceptual framework distinguishing manipulate(X), select(X), and observe(X) theories; terminological concept analysis following Nuopponen (2008)},
  external_validity = {Leadership and management research broadly; directly applicable to behavioral intervention design in any applied domain},
  session_ref = {},
  notes = {Framework paper from University of Lausanne distinguishing three types of practical theories based on causal construct manipulability. manipulate(X) theories have causal constructs whose levels practitioners can directly set (e.g. goal difficulty, defaults, charismatic signals). select(X) theories allow selection on construct levels (e.g. trait-based hiring). observe(X) theories only permit measurement (e.g. trust, fairness perceptions). Identifies three conceptual flaws undermining actionable theory: (1) simplification fallacy - reducing complex phenomena to single constructs (culture, LMX); (2) endogenous-cause problem - treating endogenous constructs as exogenous (abusive supervision, justice perceptions, trust); (3) construct conflation - mixing cause and effect in one construct (authentic leadership, OCB, burnout). Key criterion for actionable constructs: construct unity, manipulability, explicit mechanism. Directly relevant to EBF: the 10C framework and intervention design workflow (/design-intervention) are explicitly manipulate(X) - they identify concrete levers (defaults, norms, incentives) rather than explanatory causes (trust, satisfaction). References Thaler/Sunstein (2008) nudges, Locke/Latham goal-setting, Antonakis charismatic signaling, and cognitive evaluation theory (Deci et al. 1999 crowding-out) as exemplary actionable theories. Open Access CC BY 4.0.},
}

@article{ronkko2023pls,
  title = {Marketing or Methodology? Exposing the Fallacies of {PLS} with Simple Demonstrations},
  author = {R{\"o}nkk{\"o}, Mikko and Lee, Nick and Evermann, Joerg and McIntosh, Cameron and Antonakis, John},
  journal = {European Journal of Marketing},
  year = {2023},
  volume = {57},
  number = {6},
  pages = {1597--1617},
  doi = {10.1108/EJM-02-2021-0099},
  publisher = {Emerald},
  use_for = {LIT-O, METHOD-LLMMC},
  theory_support = {},
  evidence_tier = {2},
  parameter = {CEI_cutoff: 0.95 composite equivalence index threshold; PLS_reliability_gain: 0.6pct in favorable conditions; PLS_reliability_loss: 16.8pct in unfavorable conditions; unit_weight_superiority_threshold: inter_item_r >= 0.4},
  identification = {Empirical demonstrations using three public data sets (ECSI, corporate reputation, TAM); simulation studies; analytical derivations},
  external_validity = {All social science research using PLS-SEM; directly relevant to EBF measurement and parameter estimation methodology},
  session_ref = {},
  notes = {Methodological critique demonstrating three PLS fallacies: (1) PLS does NOT maximize R2 - canonical correlation produces higher R2; (2) PLS weights do NOT improve reliability - unit weights perform equally or better; (3) PLS AVE/CR statistics cannot detect model misspecification - even randomly assigned indicators pass quality thresholds. Introduces Composite Equivalence Index (CEI) to test whether PLS weights differ meaningfully from unit weights. Key finding: PLS composites correlate 0.99+ with unweighted composites in typical data. PLS capitalizes on chance in small samples (biased away from zero). Cross-loadings are exacerbated by PLS weighting. Co-authored by Antonakis (Lausanne). Directly relevant to EBF: validates our approach of using simple measurement (parameter registry with explicit values) rather than complex latent variable methods. Supports Three-Layer Architecture principle - compute with explicit parameters rather than relying on opaque statistical methods. Open Access CC BY 4.0.},
}

