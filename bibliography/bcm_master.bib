  evidence_tier = {2},
  use_for = {CAT-25, CORE-AWARE, LIT-O},
  theory_support = {MS-AI-002},
  parameter = {augmentation_vs_automation: augmentation (human+AI) preferred over full automation; expertise_moderator: experts show stronger aversion than novices},
  identification = {systematic literature review},
  external_validity = {augmented decision making, human-AI collaboration},
  session_ref = {ubs-growth-marketing-analyses},
