@article{thaler1980toward,
  title={Toward a Positive Theory of Consumer Choice},
  author={Thaler, Richard},
  use_for = {LIT-KT, LIT-THALER},
  theory_support = {MS-RD-001},
  journal={Journal of Economic Behavior \& Organization},
  volume={1},
  number={1},
  pages={39--60},
  year={1980}
,
  doi = {10.1016/0167-2681(80)90051-7},
  ebf_reference_count = {11},
  ebf_migration_status = {migrated}
,
  abstract = {The economic theory of the consumer is a combination of positive and normative theories. Since it is based on a rational maximizing model it describes how consumers should choose, but it is alleged to also describe how they do choose. This paper argues that in certain well-defined situations many consumers act in a manner that is inconsistent with economic theory. In these situations economic theory will make systematic errors in predicting behavior. Evidence from psychology and economics is presented indicating the nature of these errors.},
  evidence_tier = {2},
}

@article{benartzi1995myopic,
  title={Myopic Loss Aversion and the Equity Premium Puzzle},
  author={Benartzi, Shlomo and Thaler, Richard H},
  journal={Quarterly Journal of Economics},
  volume={110},
  number={1},
  pages={73--92},
  year={1995},
  % === EVIDENCE CLASSIFICATION (METHOD-EVIDENCE XX) ===
  evidence_tier = {1},
  use_for = {CORE-WHERE, DOMAIN-FINANCE, LIT-BENARTZI, LIT-KT, LIT-O, parameter},
  parameter = {lambda = 2.5, evaluation_period = 1_year},
  identification = {calibration, market_data, theoretical},
  external_validity = {US_market, equity_premium_puzzle}
,
  abstract = {The equity premium puzzle refers to the empirical fact that stocks have greatly outperformed bonds over the last century. The authors offer a new explanation based on prospect theory. The explanation has two components: First, investors are assumed to be loss averse, meaning that they are distinctly more sensitive to losses than to gains. Second, even long-term investors are assumed to evaluate their portfolios frequently. They dub this combination myopic loss aversion. Using simulations, they find that the size of the equity premium is consistent with prospect theory parameters if investors evaluate their portfolios annually.},
  theory_support = {MS-RD-001},
}

