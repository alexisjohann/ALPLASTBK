\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{fehradvice-colors}[2026/01/26 FehrAdvice Color Definitions]

\RequirePackage{xcolor}

% =============================================================================
% PRIMARY COLORS
% =============================================================================

% Dunkelblau - Headlines, Links, Akzente
\definecolor{fadarkblue}{RGB}{2,64,121}
\definecolor{faprimary}{RGB}{2,64,121}

% Hellblau - Sekundäre Elemente
\definecolor{falightblue}{RGB}{84,158,222}
\definecolor{fasecondary}{RGB}{84,158,222}

% Dunkelgrau - Fliesstext
\definecolor{fadarkgray}{RGB}{37,33,42}
\definecolor{fatext}{RGB}{37,33,42}

% Hellgrau - Hintergründe
\definecolor{falightgray}{RGB}{243,245,247}
\definecolor{fabackground}{RGB}{243,245,247}

% =============================================================================
% SECONDARY COLORS
% =============================================================================

% Flieder - Akzente, Diagramme
\definecolor{falilac}{RGB}{161,160,198}

% Mintgrün - Akzente, Diagramme
\definecolor{famint}{RGB}{126,189,172}

% Ocker - Hervorhebungen
\definecolor{faocher}{RGB}{222,203,63}

% Orange - Warnungen, Call-to-Action
\definecolor{faorange}{RGB}{222,157,62}

% =============================================================================
% ADDITIONAL COLORS
% =============================================================================

% Weiss
\definecolor{fawhite}{RGB}{255,255,255}

% Rahmenlinien (Tabellen)
\definecolor{faborder}{RGB}{224,224,224}

% =============================================================================
% COLOR ALIASES (for compatibility)
% =============================================================================

\colorlet{primarydarkblue}{fadarkblue}
\colorlet{primarylightblue}{falightblue}
\colorlet{primarydarkgray}{fadarkgray}
\colorlet{primarylightgray}{falightgray}
\colorlet{secondarylilac}{falilac}
\colorlet{secondarymint}{famint}
\colorlet{secondaryocher}{faocher}
\colorlet{secondaryorange}{faorange}

% =============================================================================
% DIAGRAM COLOR SEQUENCE
% =============================================================================
% For charts with multiple data series, use in this order:
% 1. fadarkblue
% 2. falightblue
% 3. famint
% 4. falilac
% 5. faocher
% 6. faorange

