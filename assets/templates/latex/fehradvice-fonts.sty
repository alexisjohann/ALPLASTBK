% =============================================================================
% FEHRADVICE FONT DEFINITIONS
% =============================================================================
% Based on: Corporate-Identity-Guide-FAP-EN-231007 2.pdf (Page 11)
% Version: 1.0 (January 2026)
%
% Official Fonts:
%   Headlines:    Roboto Bold
%   Subheadlines: Roboto Regular
%   Body:         Open Sans Regular
%   Accents:      Playfair Display
%   Code:         Consolas / Inconsolata
%
% Requires: XeLaTeX or LuaLaTeX for system fonts
% =============================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{fehradvice-fonts}[2026/01/26 FehrAdvice Font Definitions]

\RequirePackage{fontspec}
\RequirePackage{fehradvice-colors}

% =============================================================================
% FONT SETUP
% =============================================================================

% Main font: Open Sans (body text)
\setmainfont{Open Sans}[
    UprightFont = *-Regular,
    BoldFont = *-Bold,
    ItalicFont = *-Italic,
    BoldItalicFont = *-BoldItalic,
    Scale = 1.0
]

% Sans-serif font: Roboto (headlines)
\setsansfont{Roboto}[
    UprightFont = *-Regular,
    BoldFont = *-Bold,
    ItalicFont = *-Italic,
    BoldItalicFont = *-BoldItalic,
    Scale = 1.0
]

% Monospace font: Inconsolata (code) - fallback for Consolas
\setmonofont{Inconsolata}[
    Scale = 0.95
]

% Accent font: Playfair Display (quotes, special text)
\newfontfamily\accentfont{Playfair Display}[
    UprightFont = *-Regular,
    BoldFont = *-Bold,
    ItalicFont = *-Italic,
    BoldItalicFont = *-BoldItalic
]

% =============================================================================
% HEADING STYLES
% =============================================================================

\RequirePackage{titlesec}

% Chapter: 28pt Roboto Bold, Dunkelblau
\titleformat{\chapter}[display]
    {\sffamily\bfseries\Huge\color{fadarkblue}}
    {\chaptertitlename\ \thechapter}
    {20pt}
    {\Huge}

% Section: 22pt Roboto Bold, Dunkelblau
\titleformat{\section}
    {\sffamily\bfseries\LARGE\color{fadarkblue}}
    {\thesection}
    {1em}
    {}

% Subsection: 16pt Roboto Regular, Dunkelblau
\titleformat{\subsection}
    {\sffamily\large\color{fadarkblue}}
    {\thesubsection}
    {1em}
    {}

% Subsubsection: 13pt Roboto Regular, Dunkelblau
\titleformat{\subsubsection}
    {\sffamily\normalsize\color{fadarkblue}}
    {\thesubsubsection}
    {1em}
    {}

% =============================================================================
% TEXT COLOR
% =============================================================================

% Set default text color to Dunkelgrau
\AtBeginDocument{\color{fadarkgray}}

% =============================================================================
% ACCENT COMMANDS
% =============================================================================

% For quotes and special accent text
\newcommand{\faaccent}[1]{{\accentfont\color{fadarkblue}#1}}
\newcommand{\faquote}[1]{{\accentfont\itshape\color{fadarkblue}«#1»}}

% =============================================================================
% FALLBACK (for pdfLaTeX compatibility)
% =============================================================================

% If fontspec is not available, use standard fonts
\@ifpackageloaded{fontspec}{}{
    \RequirePackage[T1]{fontenc}
    \RequirePackage{helvet}
    \renewcommand{\familydefault}{\sfdefault}
    \PackageWarning{fehradvice-fonts}{%
        fontspec not available. Using Helvetica as fallback.
        For proper fonts, compile with XeLaTeX or LuaLaTeX.
    }
}

\endinput
