%% -----------------------------------------------------------------------------
%% FEHRADVICE FARBEN - Primärfarben
%% -----------------------------------------------------------------------------
\definecolor{primarydarkblue}{RGB}{2,64,121}       % #024079 - Dunkelblau
\definecolor{primarylightblue}{RGB}{84,158,222}    % #549EDE - Hellblau
\definecolor{primarydarkgray}{RGB}{37,33,42}       % #25212A - Dunkelgrau (Text)
\definecolor{primarylightgray}{RGB}{245,245,245}   % #F5F5F5 - Hellgrau (Hintergründe)

%% -----------------------------------------------------------------------------
%% FEHRADVICE FARBEN - Sekundärfarben
%% -----------------------------------------------------------------------------
\definecolor{secondarylilac}{RGB}{161,160,198}     % #A1A0C6 - Flieder
\definecolor{secondarymint}{RGB}{126,189,172}      % #7EBDAC - Mintgrün
\definecolor{secondaryocher}{RGB}{222,203,63}      % #DECB3F - Ocker
\definecolor{secondaryorange}{RGB}{222,157,62}     % #DE9D3E - Orange

%% Legacy-Aliase für Kompatibilität
\definecolor{trustblue}{RGB}{2,64,121}
\definecolor{trustbluelight}{RGB}{212,228,244}
\definecolor{fehrgray}{RGB}{37,33,42}
\definecolor{fehrlightgray}{RGB}{245,245,245}

%% -----------------------------------------------------------------------------
%% PARAMETER (werden vom Script überschrieben)
%% -----------------------------------------------------------------------------
\newcommand{\FAYear}{2026}
\newcommand{\FALogoPath}{assets/fehradvice-logo.png}

%% -----------------------------------------------------------------------------
%% LOGO-HANDLING MIT FALLBACK
%% -----------------------------------------------------------------------------
\newcommand{\FALogo}{%
  \IfFileExists{\FALogoPath}{%
    \includegraphics[width=4cm]{\FALogoPath}%
  }{%
    \colorbox{trustblue}{\makebox[4cm][c]{\color{white}\Large\textbf{FehrAdvice}}}%
  }%
}

\pagestyle{empty}

%% =============================================================================
%% BACK PAGE COMMAND
%% =============================================================================
\newcommand{\FABackPage}{%
\thispagestyle{empty}

\begin{tikzpicture}[remember picture, overlay]
    % Hintergrund (Hellgrau)
    \fill[fehrlightgray] (current page.south west) rectangle (current page.north east);

    % Oberer blauer Balken (dünn, 1cm)
    \fill[trustblue] ([yshift=-1cm]current page.north west) rectangle (current page.north east);

    % Unterer blauer Balken (4cm)
    \fill[trustblue] (current page.south west) rectangle ([yshift=4cm]current page.south east);
\end{tikzpicture}

\vspace*{6cm}

\begin{center}
    % FehrAdvice Logo
    \FALogo

    \vspace{0.5cm}

