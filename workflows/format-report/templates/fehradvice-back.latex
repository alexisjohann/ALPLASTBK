    \vspace{0.5cm}

    {\color{black}\normalsize
    Binzmühlestrasse 170A\\
    8050 Zürich\\
    Schweiz
    }

    \vspace{0.8cm}

    {\color{trustblue}\normalsize
    info@fehradvice.com\\[0.2cm]
